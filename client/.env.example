# NexMeet Client Environment Variables
# Copy this file to .env and fill in your values

# ─── REQUIRED FOR TRANSLATION ─────────────────────────────────────────────
# Google Gemini API key — FREE at https://aistudio.google.com/app/apikey
# This is used directly from the browser for live translation.
VITE_GEMINI_API_KEY=AIza...

# ─── Optional: API / Socket server URL ────────────────────────────────────
# Leave empty to use Vite proxy in dev (server must be running on port 3001)
VITE_SOCKET_URL=

# In production, set this to your deployed server:
# VITE_SOCKET_URL=https://your-nexmeet-server.com
