# NexMeet Server Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Google Gemini AI (FREE — get key at https://aistudio.google.com/app/apikey)
# Free tier: 15 requests/min, 1,500 requests/day, 1M tokens/day
GEMINI_API_KEY=AIza...

# Firebase Admin (optional — for persistent storage)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Supabase (alternative to Firebase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
